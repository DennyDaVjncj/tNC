<div class="grid">
  <div class="grid_item--large--five-sixths push--large-one-twelfth">
    
    <header class="section-header text-center">
      <h1>{{ page.title }}</h1>
      <hr class="hr--small">
    </header>
    
    <div class="grid">
      <div class="grid_item large--four-fiths push--large--one-tenth">
        <div class="rte rte--nomargin rte--indented-images">
          {{ page.content }}
        </div>
        
        <div id="gamify-panel" data-id="{{ shop.permanent_domain }}" style="text-align: center;"></div>
        
      </div>
    </div>
    
  </div>
</div>          